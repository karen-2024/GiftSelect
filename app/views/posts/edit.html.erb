<h3>POST 編集</h3>

<%= form_with model: @post do |f| %>
  <li>
    <label for="inputImage"></label>
    <%= f.file_field :image, placeholder: "商品画像", accept: "image/*" %>  
  </li>
  <li>
    <label for="inputName">商品名</label>
    <%= f.text_field :name, autofocus: true, id:"inputName", placeholder:"商品名"%>
  </li>
  <li>
    <label for="inputIntroduction">商品説明</label>
    <%= f.text_area :introduction, autofocus: true, id:"inputIntroduction", placeholder:"商品説明"%>
  </li>
  <li>
    <label for="inputAmount">個数</label>
    <%= f.number_field :amount, autofocus: true, id:"inputAmount", placeholder:"個数（例：20）"%>個
  </li>

  <!--個包装  有無 選択-->

  <li>
    <label for="inputPrice">価格</label>
    <%= f.number_field :price, autofocus: true, id:"inputPrice", placeholder:"1500"%>円
  </li>
  <li>
    <label for="inputPrefecture">都道府県</label>
    <%= f.select :prefecture, Post.prefectures.keys.map, autofocus: true, id:"inputPrefecture", placeholder:"都道府県"%>
  </li>
  <li>
    <label for="inputLocation">場所（詳細）</label>
    <%= f.text_field :location, autofocus: true, id:"inputIocation", placeholder:"例：○○○市、～～店"%>
  </li>
  <li>
    <label for="inputRecommend">贈る相手・オススメ</label>
    <%= f.select :recommend, Post.recommends.keys.map, autofocus: true, id:"inputRecommend", placeholder:"都道府県"%>
  </li>

  <%= f.submit "変更を保存" %>
<% end %>
