<h2>POST詳細</h2>

<!--編集ボタン-->
  <% if @post.user == current_user %>
    <%= link_to "Edit",edit_post_path(@post) %>
  <% end %>
　　
<!--削除ボタン-->
  <% if @post.user == current_user %>
    <%= link_to "Delete", post_path(@post), method: :delete %>
  <% end %>

<div class="row">
  <div class="col">
    <p>投稿日：<%= @post.created_at.strftime('%Y/%m/%d') %></p>
    <p><%= image_tag @post.get_image(500,500) %></p>

    <br>
    <h4>商品名：<%= @post.name %></h4>
    <p>説明：<%= @post.introduction %></p>

    <br>
    <p>
      数量：<%= @post.amount %>　　
      個包装：<%= @post.package %>
    </p>
    <p>価格：<%= @post.price %>円</p>
    <p>
      場所：<%= @post.prefecture %>　　
      詳細：<%= @post.location %>
    </p>
    <p>「<%= @post.recommend %>」オススメ</P>
    <p>
      <% if @post.favorited_by?(current_user) %>
        <%= link_to post_favorite_path(@post), method: :delete do %>
          いいね： ★<%= @post.favorites.count %>
        <% end %>
      <% else %>
        <%= link_to post_favorite_path(@post), method: :post do %>
          いいね： ☆<%= @post.favorites.count %>
        <% end %>
      <% end %>　　
      コメント件数： <%= @post.post_comments.count %>
    </p>
    <br>

    <table class="user">
      <tr>
        <td>
          <p><%= image_tag @post.user.get_profile_image(80,80) %></p>
          <p><%= link_to @post.user.name, user_path(@user.id) %></p>
        </td>
        <td>
          <h4>Title：<%= @post.title %></h4>
          <p>Review：<%= @post.review %></p>
        </td>
      </tr>
    </table>

    <h3>コメント</h3>
    <table class="comment">
      <tr>
        <%= form_with model: [@post, @post_comment] do |f| %>
          <td><%= f.text_area :comment, cols: '50', placeholder: "コメントをここに" %></td>
          <td><%= f.submit "送信する" %></td>
        <% end %>
      </tr>

      <% @post.post_comments.each do |post_comment| %>
        <tr>
          <td>
            <p><%= image_tag post_comment.user.get_profile_image(80,80) %></p>
            <p><%= post_comment.user.name %></p>
          </td>
          <td>
            <%= post_comment.comment %>
          </td>
          <td>
            <% if post_comment.user == current_user %>
              <%= link_to "Delete", post_post_comment_path(post_comment.post, post_comment), method: :delete %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </table>

  </div>
</div>