
<div class="row">
    <div class="card-columns">

      <% posts.each do |post| %>
        <div class="card">

          <div class="card-body rounded">
            <p>投稿日：<%= post.created_at.strftime('%Y/%m/%d') %></p>
            <!--商品画像-->
            <%= link_to post_path(post.id) do %>
              <%= image_tag post.get_image(300,300) %>
            <% end %>

            <br><br>
            <strong>商品名：<%= post.name %></strong>
            <p><%= post.introduction %></p>

            <p>場所：<%= post.prefecture %></p>
            <p>「<%= post.recommend %>」オススメ</p>

            <!--ユーザー情報-->
            <p>User_name：<%= post.user.name %></p>

            <!--いいね・コメント-->
            <p>
              <%= link_to "★いいね： #{post.favorites.count}", post_path(post.id) %>　　
              <%= link_to "コメント： #{post.post_comments.count}", post_path(post.id) %>
            </p>
          </div>

        </div>
      <% end %>

    </div>
</div>